{
  "semverGroups": [
    {
      "label": "use exact version numbers",
      "packages": ["**"],
      "dependencyTypes": ["dev", "prod"],
      "dependencies": ["**"],
      "range": ""
    }
  ],
  "versionGroups": [
    {
      "label": "Ignore everything except dependencies, devDependencies, and peerDependencies",
      "dependencies": ["!prod", "!dev", "!peer"],
      "isIgnored": true
    },
    {
      "label": "New versions of @antfu/eslint-config may add unwanted rules.",
      "packages": ["**"],
      "dependencies": ["@antfu/eslint-config"],
      "pinVersion": "2.15.0"
    },
    {
      "label": "Please use lodash-es instead of lodash",
      "packages": ["**"],
      "dependencies": ["lodash"],
      "isBanned": true
    },
    {
      "label": "UnoCSS Dependencies should be same version",
      "dependencies": ["unocss", "@unocss/**"],
      "pinVersion": "0.64.0"
    }
  ]
}
