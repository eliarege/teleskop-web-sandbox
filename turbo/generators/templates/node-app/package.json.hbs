{
  "name": "{{ project }}",
  "type": "module",
  "version": "{{ version }}",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx --env-file-if-exists=.env src/server.ts | pino-pretty",
    "build": "unbuild",
    "preview": "NODE_ENV=production node --env-file-if-exists=.env dist/server.mjs",
    "start": "node dist/server.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "keycloak": "../../keycloak/keycloak.sh"
  },
  "dependencies": {
    {{#if teleskop}}
    "knex": "3.1.0",
    "tedious": "18.6.1",
    {{/if}}
    {{#if fastify}}
    "fastify": "4.26.2",
    {{/if}}
    "@teleskop/utils": "workspace:*",
    "pino": "9.5.0"
  },
  "devDependencies": {
    "@teleskop/build-utils": "workspace:*",
    "@teleskop/tsconfig": "workspace:*",
    "@types/node": "22.9.0",
    "eslint": "9.14.0",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "unbuild": "2.0.0"
  }
}
