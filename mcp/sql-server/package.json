{
  "name": "@teleskop-mcp/sql-server",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only MCP server for SQL Server database operations",
  "keywords": [
    "mcp",
    "sql-server",
    "database",
    "read-only"
  ],
  "bin": {
    "teleskop-mcp-sqlserver": "src/server.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.25.0",
    "dotenv": "17.2.3",
    "mssql": "11.0.1",
    "yargs": "18.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/mssql": "9.1.5",
    "@types/node": "22.9.0",
    "@types/yargs": "17.0.35",
    "typescript": "5.6.3"
  }
}
