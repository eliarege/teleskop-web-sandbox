{
  "name": "websockify",
  "type": "module",
  "version": "0.2.2",
  "description": "NoVNC için WebSocket Proxy. Teleskopta tanımlanmış cihazlardaki VNC sunucularına WebSocket trafiğini yönlendirir.",
  "license": "UNLICENSED",
  "main": "dist/server.mjs",
  "scripts": {
    "dev": "NODE_ENV=development tsx -r dotenv/config src/server.ts | pino-pretty",
    "start": "node dist/server.mjs",
    "preview": "NODE_ENV=production node -r dotenv/config dist/server.mjs | pino-pretty",
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "knex": "^2.5.1",
    "pino": "^8.16.1",
    "tedious": "^16.5.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^18.18.6",
    "@types/ws": "^8.5.8",
    "pino-pretty": "^9.4.1",
    "tsconfig": "workspace:*",
    "typescript": "^5.2.2",
    "unbuild": "2.0.0"
  },
  "eliar": {
    "type": "node",
    "port": 6800,
    "outDir": "dist"
  }
}
