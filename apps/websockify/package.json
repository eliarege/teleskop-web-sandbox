{
  "name": "websockify",
  "type": "module",
  "version": "0.2.2",
  "private": true,
  "description": "NoVNC için WebSocket Proxy. Teleskopta tanımlanmış cihazlardaki VNC sunucularına WebSocket trafiğini yönlendirir.",
  "license": "UNLICENSED",
  "main": "dist/server.mjs",
  "scripts": {
    "dev": "NODE_ENV=development tsx -r dotenv/config --import ./dev/clipboard.js src/server.ts | pino-pretty",
    "start": "node dist/server.mjs",
    "preview": "NODE_ENV=production node -r dotenv/config dist/server.mjs | pino-pretty",
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "keycloak": "../../keycloak/keycloak.sh"
  },
  "dependencies": {
    "jose": "^5.1.3",
    "knex": "^3.0.1",
    "pino": "^8.16.2",
    "tedious": "^16.6.1",
    "utils": "workspace:*",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.6",
    "@types/ws": "^8.5.10",
    "build-utils": "workspace:*",
    "clipboardy": "^4.0.0",
    "pino-pretty": "^10.2.3",
    "tsconfig": "workspace:*",
    "tsx": "^4.6.1",
    "typescript": "^5.3.2",
    "unbuild": "2.0.0"
  },
  "eliar": {
    "type": "node",
    "port": 6800,
    "outDir": "dist"
  }
}
