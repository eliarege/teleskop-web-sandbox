{
  "name": "websockify",
  "type": "module",
  "version": "0.78.0",
  "private": true,
  "description": "NoVNC için WebSocket Proxy. Teleskopta tanımlanmış cihazlardaki VNC sunucularına WebSocket trafiğini yönlendirir.",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx --env-file-if-exists=.env --import ./dev/clipboard.js src/server.ts | pino-pretty",
    "start": "node dist/server.mjs",
    "preview": "NODE_ENV=production node --env-file-if-exists=.env dist/server.mjs | pino-pretty",
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "keycloak": "../../keycloak/keycloak.sh"
  },
  "dependencies": {
    "@teleskop/utils": "workspace:*",
    "jose": "5.9.6",
    "knex": "3.1.0",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "tedious": "18.6.1",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@teleskop/build-utils": "workspace:*",
    "@teleskop/tsconfig": "workspace:*",
    "@types/node": "22.9.0",
    "@types/ws": "8.5.13",
    "clipboardy": "4.0.0",
    "eslint": "9.14.0",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "unbuild": "2.0.0"
  }
}
