{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Node",
    "checkJs": true,
    "allowJs": true,
    "lib": ["ES2021", "ES2021.String"],
    "target": "ES2021",
    "jsx": "preserve",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "dist/"
  ]
}
