{
  // Enable the ESlint flat config support
  "eslint.experimental.useFlatConfig": true,

  // Disable the default formatter, use eslint instead
  "prettier.enable": false,
  "editor.formatOnSave": false,

  // Auto fix
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },

  "json.schemas": [
    {
      "fileMatch": ["apps/*/manifest.json"],
      "url": "./schemas/manifest.schema.json"
    },
    {
      "fileMatch": ["apps/*/package.json"],
      "url": "./schemas/package.schema.json"
    }
  ],

  // Silent the stylistic rules in you IDE, but still auto fix them
  "eslint.rules.customizations": [
    { "rule": "style/*", "severity": "off" },
    { "rule": "*-indent", "severity": "off" },
    { "rule": "*-spacing", "severity": "off" },
    { "rule": "*-spaces", "severity": "off" },
    { "rule": "*-order", "severity": "off" },
    { "rule": "*-dangle", "severity": "off" },
    { "rule": "*-newline", "severity": "off" },
    { "rule": "*quotes", "severity": "off" },
    { "rule": "*semi", "severity": "off" }
  ],

  // Enable eslint for all supported languages
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "json",
    "jsonc",
    "yaml"
  ],

  // Remove red foreground from align attribute in vue files
  "editor.tokenColorCustomizations": {
    "[Default Dark Modern]": {
      "textMateRules": [{
        "scope": [
          "source.vue meta.attribute.align.html invalid"
        ],
        "settings": {
          "foreground": "#9cdcfe"
        }
      }]
    }
  },

  // https://docs.gitlab.com/ee/ci/yaml/yaml_optimization.html#reference-tags
  "yaml.customTags": ["!reference"]
}
