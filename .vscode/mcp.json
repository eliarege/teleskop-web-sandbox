{
  "servers": {
    "mssql-mcp-server": {
      "command": "pnpm",
      "cwd": "${workspaceFolder}",
      "args": [
        "-w",
        "exec",
        "teleskop-mcp-sqlserver"
      ],
      "env": {
        "DB_USER": "",
        "DB_PASSWORD": "",
        "DB_SERVER": "",
        "DB_DATABASE": "",
        "DB_TRUST_SERVER_CERT": "true"
      }
    },
    "gitlab-merge-request": {
      "command": "pnpm",
      "cwd": "${workspaceFolder}",
      "args": [
        "-w",
        "exec",
        "teleskop-mcp-gitlab-mr"
      ],
      "env": {
        "GITLAB_HOST": "https://gitlab.com",
        "GITLAB_PROJECT_ID": "50621216"
      }
    },
    "nuxt": {
      "type": "http",
      "url": "https://nuxt.com/mcp"
    }
  }
}
