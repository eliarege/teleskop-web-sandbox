{
  "name": "teleskop-web",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "keycloak": "./keycloak/keycloak.sh",
    "cleanup": "find ./ \\( -type f -name \"pnpm-lock.*.yaml\" -o -type d -name \"node_modules\" -o -type d -name \".nuxt\" \\) -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@teleskop/eslint-config": "workspace:*",
    "syncpack": "13.0.0",
    "turbo": "2.2.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@azure/identity": "3",
        "eslint": "9"
      },
      "ignoreMissing": [
        "webpack"
      ]
    }
  }
}
