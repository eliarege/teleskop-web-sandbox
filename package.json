{
  "name": "teleskop-web",
  "type": "module",
  "version": "0.64.0",
  "private": true,
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "keycloak": "./keycloak/keycloak.sh",
    "cleanup": "find ./ \\( -type f -name \"pnpm-lock.*.yaml\" -o -type d -name \"node_modules\" -o -type d -name \".nuxt\" \\) -prune -exec rm -rf '{}' +",
    "bump": "./scripts/bump-version",
    "generate-env": "./scripts/generate-env"
  },
  "devDependencies": {
    "@teleskop/eslint-config": "workspace:*",
    "@turbo/gen": "2.5.8",
    "git-cliff": "2.10.1",
    "syncpack": "13.0.0",
    "turbo": "2.5.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@azure/identity": "3",
        "eslint": "9"
      },
      "ignoreMissing": [
        "webpack"
      ]
    },
    "patchedDependencies": {
      "@nuxtjs/i18n": "patches/@nuxtjs__i18n.patch",
      "httpxy": "patches/httpxy.patch",
      "@novnc/novnc": "patches/@novnc__novnc.patch",
      "quasar@2.18.6": "patches/quasar@2.18.6.patch"
    }
  }
}
