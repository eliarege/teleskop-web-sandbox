{
  "name": "teleskop-web",
  "type": "module",
  "version": "0.73.1",
  "private": true,
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "keycloak": "./keycloak/keycloak.sh",
    "cleanup": "find ./ \\( -type f -name \"pnpm-lock.*.yaml\" -o -type d -name \"node_modules\" -o -type d -name \".nuxt\" \\) -prune -exec rm -rf '{}' +",
    "bump": "./scripts/bump-version",
    "generate-env": "./scripts/generate-env"
  },
  "devDependencies": {
    "@teleskop/eslint-config": "workspace:*",
    "@turbo/gen": "2.5.8",
    "git-cliff": "2.12.0",
    "syncpack": "13.0.0",
    "turbo": "2.5.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@azure/identity": "3",
        "eslint": "9"
      },
      "ignoreMissing": [
        "webpack"
      ]
    },
    "patchedDependencies": {
      "@nuxtjs/i18n": "patches/@nuxtjs__i18n.patch",
      "httpxy": "patches/httpxy.patch",
      "@novnc/novnc": "patches/@novnc__novnc.patch",
      "quasar@2.18.6": "patches/quasar@2.18.6.patch",
      "@types/nearley": "patches/@types__nearley.patch"
    }
  }
}
