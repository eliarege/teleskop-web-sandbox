{
  "name": "teleskop-web",
  "type": "module",
  "version": "0.45.3",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "keycloak": "./keycloak/keycloak.sh",
    "cleanup": "find ./ \\( -type f -name \"pnpm-lock.*.yaml\" -o -type d -name \"node_modules\" -o -type d -name \".nuxt\" \\) -prune -exec rm -rf '{}' +",
    "bump": "./scripts/bump-version"
  },
  "devDependencies": {
    "@teleskop/eslint-config": "workspace:*",
    "git-cliff": "2.10.0",
    "syncpack": "13.0.0",
    "turbo": "2.5.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@azure/identity": "3",
        "eslint": "9"
      },
      "ignoreMissing": [
        "webpack"
      ]
    },
    "patchedDependencies": {
      "@nuxtjs/i18n": "patches/@nuxtjs__i18n.patch"
    }
  }
}
