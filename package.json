{
  "name": "teleskop-web",
  "type": "module",
  "version": "0.72.0",
  "private": true,
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "keycloak": "./keycloak/keycloak.sh",
    "cleanup": "find ./ \\( -type f -name \"pnpm-lock.*.yaml\" -o -type d -name \"node_modules\" -o -type d -name \".nuxt\" \\) -prune -exec rm -rf '{}' +",
    "bump": "./scripts/bump-version",
    "generate-env": "./scripts/generate-env"
  },
  "devDependencies": {
    "@teleskop/eslint-config": "workspace:*",
    "@turbo/gen": "2.5.8",
    "git-cliff": "2.12.0",
    "syncpack": "13.0.0",
    "turbo": "2.5.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@azure/identity": "3",
        "eslint": "9"
      },
      "ignoreMissing": [
        "webpack"
      ]
    },
    "patchedDependencies": {
      "@nuxtjs/i18n": "patches/@nuxtjs__i18n.patch",
      "httpxy": "patches/httpxy.patch",
      "@novnc/novnc": "patches/@novnc__novnc.patch",
      "quasar@2.18.6": "patches/quasar@2.18.6.patch",
      "@types/nearley": "patches/@types__nearley.patch"
    }
  }
}
