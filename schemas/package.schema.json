{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/package"
    },
    {
      "type": "object",
      "properties": {
        "eliar": {
          "type": "object",
          "description": "Eliar App Metadata for Development Tasks",
          "properties": {
            "type": {
              "enum": ["node", "nuxt"],
              "description": "Type of application (nuxt or node)",
              "$comment": "Should migrate to manifest.json"
            },
            "port": {
              "type": "number",
              "description": "Default exposed port of app"
            },
            "outDir": {
              "type": "string",
              "description": "Build script output directory"
            }
          },
          "required": ["type"]
        }
      },
      "required": ["eliar"]
    }
  ]
}
