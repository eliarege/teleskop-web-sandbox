{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "definitions": {
    "port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    }
  },
  "properties": {
    "roles": {
      "type": "array",
      "description": "List of client roles",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Role name"
          },
          "description": {
            "type": "string",
            "description": "Role description"
          }
        },
        "required": ["name"]
      }
    },
    "ports": {
      "type": "array",
      "items": {
        "anyOf": [
          { "$ref": "#/definitions/port" },
          {
            "type": "object",
            "properties": {
              "protocol": { "enum": ["tcp", "udp"] },
              "port": { "$ref": "#/definitions/port" }
            }
          }
        ]
      }
    },
    "envDependencies": {
      "type": "array",
      "description": "Environment dependencies that should be installed via apk",
      "items": {
        "type": "string"
      }
    }
  }
}
